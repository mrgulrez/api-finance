# ─── Django Core ──────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-replace-this-in-production

DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite (no config needed)
# For PostgreSQL: DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=sqlite:///db.sqlite3

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Logging ──────────────────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO

# ─── Email Configuration (Gmail SMTP) ─────────────────────────────────────────
# Create a Gmail App Password at: https://myaccount.google.com/apppasswords
# App Passwords require 2-Step Verification to be enabled on your Google account.
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=Finance System <your-gmail@gmail.com>

# ─── Frontend URL (used in email links) ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173
